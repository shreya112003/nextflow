# ── Clerk Auth ─────────────────────────────────────────────────────────────────
# Get from https://clerk.com → Create Application
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxx
CLERK_SECRET_KEY=sk_test_xxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/workflow
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/workflow

# ── PostgreSQL (Neon) ────────────────────────────────────────────────────────
# Get from https://neon.tech → Create Project → Connection string
DATABASE_URL="postgresql://user:pass@host/neondb?sslmode=require"

# ── Google Gemini ────────────────────────────────────────────────────────────
# Get from https://aistudio.google.com/app/apikey
GOOGLE_GEMINI_API_KEY=AIzaSy_xxxx

# ── Trigger.dev ──────────────────────────────────────────────────────────────
# Get from https://cloud.trigger.dev → Project Settings → API Keys
TRIGGER_API_KEY=tr_dev_xxxx
TRIGGER_API_URL=https://api.trigger.dev
NEXT_PUBLIC_TRIGGER_PUBLIC_API_KEY=pk_dev_xxxx

# ── Transloadit ──────────────────────────────────────────────────────────────
# Get from https://transloadit.com → Account → API Keys
TRANSLOADIT_KEY=xxxx
TRANSLOADIT_SECRET=xxxx
NEXT_PUBLIC_TRANSLOADIT_KEY=xxxx
